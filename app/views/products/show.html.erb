<% content_for :title, "Showing product" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 mb-5 bg-green-50 text-green-700 dark:bg-green-800 dark:text-green-100 font-medium rounded-md inline-block" id="notice">
      <%= notice %>
    </p>
  <% end %>

  <h1 class="font-bold text-4xl text-gray-900 dark:text-white">Showing product</h1>

  <%= render @product %>  <!-- partial _product renderuje status z ikoną -->

  <div class="mt-4 space-x-2">
    <%= link_to "Edit this product", edit_product_path(@product),
                class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-900 dark:text-white inline-block font-medium" %>

    <%= link_to "Back to products", products_path,
                class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 text-gray-900 dark:text-white inline-block font-medium" %>

    <%= button_to "Destroy this product", @product, method: :delete,
                  class: "rounded-md px-3.5 py-2.5 bg-red-600 hover:bg-red-500 text-white font-medium inline-block" %>
  </div>
</div>