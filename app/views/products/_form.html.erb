<%= form_with(model: product, local: true) do |form| %>
  <div class="mb-4">
    <%= form.label :name, class: "block font-medium mb-1" %>
    <%= form.text_field :name, class: "w-full rounded border-gray-300 dark:bg-gray-700 dark:text-white" %>
  </div>

  <div class="mb-4">
    <%= form.label :price, class: "block font-medium mb-1" %>
    <%= form.number_field :price, step: 0.01, class: "w-full rounded border-gray-300 dark:bg-gray-700 dark:text-white" %>
  </div>

  <div class="mb-4">
    <%= form.label :status, class: "block font-medium mb-1" %>
    <%= form.select :status, Product.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "w-full rounded border-gray-300 dark:bg-gray-700 dark:text-white" %>
  </div>

  <div>
    <%= form.submit "Save", class: "rounded-md px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
  </div>
<% end %>